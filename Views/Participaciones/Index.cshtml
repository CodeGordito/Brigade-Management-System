@model IEnumerable<GestorBrigadasComunitarias.Models.Participacion>

@{
    ViewData["Title"] = "Participaciones";
    var total = Model.Count();
    var asistieron = Model.Count(p => p.Asistio);
    var noAsistieron = Model.Count(p => !p.Asistio);
}

<div class="page-dark-area">
    <h1 class="page-title-dashboard">Participaciones</h1>

    <div class="row mb-4">
        <div class="col-md-4">
            <div class="dashboard-card text-center">
                <h6 class="dashboard-card-subtitle">Total Participaciones</h6>
                <h2 class="text-primary fw-bold">@total</h2>
            </div>
        </div>

        <div class="col-md-4">
            <div class="dashboard-card text-center">
                <h6 class="dashboard-card-subtitle">Asistieron</h6>
                <h2 class="text-success fw-bold">@asistieron</h2>
            </div>
        </div>

        <div class="col-md-4">
            <div class="dashboard-card text-center">
                <h6 class="dashboard-card-subtitle">No Asistieron</h6>
                <h2 class="text-danger fw-bold">@noAsistieron</h2>
            </div>
        </div>
    </div>

    <div class="dashboard-section">
        <div class="dashboard-card">
            <div class="dashboard-card-header">
                <div>
                    <h2 class="dashboard-card-title">Listado de Participaciones</h2>
                    <p class="dashboard-card-subtitle">Últimos registros creados en el sistema.</p>
                </div>

              <a asp-action="Create" class="dashboard-btn-primary">
                    + Nueva Participación
                </a>
            </div>

            <form method="get" class="row g-2 mb-3">
                <div class="col-md-10">
                    <input type="text"
                           name="buscar"
                           class="form-control"
                           placeholder="Buscar por voluntario o jornada..."
                           value="@Context.Request.Query["buscar"]" />
                </div>
                <div class="col-md-2 d-grid">
                    <button type="submit" class="dashboard-btn-primary">Buscar</button>
                </div>
            </form>

            <div class="dashboard-table-wrap">
                <table class="dashboard-table">
                    <thead>
                        <tr>
                            <th>Voluntario</th>
                            <th>Jornada</th>
                            <th>Asistencia</th>
                            <th>Horas</th>
                            <th>Observaciones</th>
                            <th>Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td>@item.Voluntario?.Nombre @item.Voluntario?.Apellido</td>
                                <td>@item.Jornada?.Titulo</td>
                                <td>
                                    @if (item.Asistio)
                                    {
                                        <span class="badge bg-success">Sí asistió</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger">No asistió</span>
                                    }
                                </td>
                                <td>@item.HorasTrabajadas</td>
                                <td>@item.Observaciones</td>
                                <td>
                                    <div class="dashboard-actions">
                                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn-edit-custom">Editar</a>
                                        <a asp-action="Details" asp-route-id="@item.Id" class="btn-details-custom">Detalles</a>
                                        <a asp-action="Delete" asp-route-id="@item.Id" class="btn-delete-custom">Eliminar</a>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>