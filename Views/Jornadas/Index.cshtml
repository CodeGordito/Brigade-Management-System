@model IEnumerable<GestorBrigadasComunitarias.Models.Jornada>

@{
    ViewData["Title"] = "Jornadas";
}

<div class="page-dark-area">
    <div class="dashboard-section">
        <div class="dashboard-card">
            <div class="dashboard-card-header">
                <div>
                    <h2 class="dashboard-card-title">Jornadas</h2>
                    <p class="dashboard-card-subtitle">Últimos registros creados en el sistema.</p>
                </div>
                <a asp-action="Create" class="dashboard-btn-primary">Nueva Jornada</a>
            </div>

            <div class="dashboard-table-wrap">
                <table class="dashboard-table">
                    <thead>
                        <tr>
                            <th>Título</th>
                            <th>Fecha</th>
                            <th>Lugar</th>
                            <th>Zona</th>
                            <th>Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td>@item.Titulo</td>
                                <td>@item.Fecha.ToString("d/M/yyyy")</td>
                                <td>@item.Lugar</td>
                                <td>@item.Zona?.Nombre</td>
                                <td>
                                    <div class="dashboard-actions">
                                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn-edit-custom">Editar</a>
                                        <a asp-action="Details" asp-route-id="@item.Id" class="btn-details-custom">Detalles</a>
                                        <a asp-action="Delete" asp-route-id="@item.Id" class="btn-delete-custom">Eliminar</a>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>