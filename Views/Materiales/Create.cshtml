@model GestorBrigadasComunitarias.Models.Material

@{
    ViewData["Title"] = "Create Material";
}

<div class="container-fluid">
    <div class="dark-card p-4">
        <h2 class="section-title mb-3">Create Material</h2>

        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div class="mb-3">
                <label asp-for="Nombre" class="form-label text-light"></label>
                <input asp-for="Nombre" class="form-control dark-input" />
            </div>

            <div class="mb-3">
                <label asp-for="Cantidad" class="form-label text-light"></label>
                <input asp-for="Cantidad" class="form-control dark-input" />
            </div>

            <div class="mb-3">
                <label asp-for="UnidadMedida" class="form-label text-light"></label>
                <input asp-for="UnidadMedida" class="form-control dark-input" />
            </div>

            <div class="mb-3">
                <label asp-for="JornadaId" class="form-label text-light"></label>
                <select asp-for="JornadaId" class="form-control dark-input" asp-items="ViewBag.JornadaId"></select>
            </div>

            <button type="submit" class="btn btn-dark-blue">Create</button>
            <a asp-action="Index" class="btn btn-secondary ms-2">Back</a>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}